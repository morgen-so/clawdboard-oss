{
  "name": "clawdboard",
  "version": "0.2.6",
  "description": "AI coding agent leaderboard — track and compare usage, costs, tokens, streaks, and model breakdowns across Claude Code, OpenCode, and Codex.",
  "type": "module",
  "bin": {
    "clawdboard": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "leaderboard",
    "usage",
    "stats",
    "vibecoding",
    "ai",
    "developer-tools",
    "cli"
  ],
  "author": {
    "name": "clawdboard",
    "url": "https://clawdboard.ai"
  },
  "homepage": "https://clawdboard.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/morgen-so/clawdboard-oss.git",
    "directory": "cli"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "ccusage": "18.0.8",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "zod": "^3.24.0"
  }
}
